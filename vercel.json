{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "functions": {
    "api/reading/vision.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/reading/vision-stitch.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/reading/vocab-vision.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/speech/synthesize.js": {
      "maxDuration": 30,
      "memory": 512
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
