# Azure Cognitive Services — Speech (神經語音 TTS)
AZURE_SPEECH_KEY=your_subscription_key_here
AZURE_SPEECH_REGION=eastasia

SPEECH_PORT=3001

# ── 閱讀理解 OCR（後端 Node.js Tesseract · 無需 Ollama）────────────
# 在專案根目錄執行: npm install tesseract.js
# 啟動: npm run dev  →  OCR API: http://localhost:3001/api/reading/health

# ── 雲端後端（Render / Railway 等）────────────────────────────────
# NODE_ENV=production
# HOST=0.0.0.0
# PORT 由平台自動注入，無需手動設定
# ALLOWED_ORIGINS=https://starship-chinese.vercel.app
#   多個網域以逗號分隔；留空則允許所有來源（開發用）

# ── Vercel 前端環境變數（在 Vercel Dashboard 設定，非本機 .env）────
# 生產環境（Vercel 部署後填寫，供 Google OAuth 回跳）
# 例：https://starship-chinese.vercel.app
VITE_APP_URL=

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# 本地開發：走 Vite proxy 可留空或填 http://localhost:3001/api/speech
# Vercel 靜態部署：填雲端後端完整網址，例如：
# VITE_SPEECH_API_URL=https://starship-chinese-api.onrender.com/api/speech
VITE_SPEECH_API_URL=http://localhost:3001/api/speech
